#!/bin/csh -f

# 1. 인자가 없으면 종료
if ($#argv == 0) then
    echo "Usage: inode <account1> <account2> ..."
    exit 1
endif

foreach acc ($argv)
    # 스크립트 실행 결과에서 계정의 4번째 필드(스토리지) 추출
    set storage = `source /user/dshk/nsh_storage_volume.csh | grep "^$acc " | awk '{print $4}'`

    if ("$storage" == "") then
        echo "[Error] $acc : No storage info found."
        continue
    endif

    # 스토리지 첫 글자 추출 (d=Dell, n=NetApp)
    set first_char = `echo $storage | cut -c1`

    echo "--- Checking Quota: $acc ($storage) ---"

    if ("$first_char" == "n") then
        # [NetApp 케이스]
        # filer -> node 변경 및 -mgt-00 추가
        set net_host = `echo $storage | sed 's/filer/node/'`"-mgt-00"
        
        # 중요: NetApp은 SSH 내부에서 grep이 안 될 수 있으므로 
        # 전체를 가져와서 로컬(현재 서버)에서 grep 처리합니다.
        sudo ssh -l admin $net_host "quota report" | grep "$acc"

    else if ("$first_char" == "d") then
        # [Dell 케이스]
        sudo ssh $storage "isi quota list -v" | grep "$acc"

    else
        echo "Unknown storage type for: $storage"
    endif

    echo ""
end
