#!/bin/csh -f

# 1. 인자 체크 (인자가 없으면 종료)
if ($#argv == 0) then
    echo "Usage: inode <account_or_storage>"
    exit 1
endif

set input = $1

# 2. 입력값이 '계정명'인지 '스토리지명'인지 판단
# nsh_storage_volume.csh 결과의 1열에서 찾으면 계정, 4열에서 찾으면 스토리지
set is_account = `source /user/dshk/nsh_storage_volume.csh | awk '{print $1}' | grep -w "$input"`
set is_storage = `source /user/dshk/nsh_storage_volume.csh | awk '{print $4}' | grep -w "$input" | head -1`

# --- [CASE 1] 계정명을 입력했을 때 ---
if ("$is_account" != "") then
    set storage = `source /user/dshk/nsh_storage_volume.csh | grep -w "^$input" | awk '{print $4}'`
    set first_char = `echo $storage | cut -c1`

    echo "--- Checking Account Quota: $input ($storage) ---"
    if ("$first_char" == "n") then
        set net_host = `echo $storage | sed 's/filer/node/'`"-mgt-00"
        sudo ssh -l admin $net_host "quota report" | grep -w "$input"
    else
        sudo ssh $storage "isi quota list -v" | grep -w "$input"
    endif

# --- [CASE 2] 스토리지명을 입력했을 때 (전체 출력) ---
else if ("$is_storage" != "") then
    set storage = $is_storage
    set first_char = `echo $storage | cut -c1`

    echo "--- Checking Full Storage Quota: $storage ---"
    if ("$first_char" == "n") then
        set net_host = `echo $storage | sed 's/filer/node/'`"-mgt-00"
        sudo ssh -l admin $net_host "quota report"
    else
        sudo ssh $storage "isi quota list -v"
    endif

else
    echo "[Error] '$input' is neither a valid account nor a recognized storage."
endif
