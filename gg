import subprocess
import sys
import re

def get_storage_info(target_accounts):
    """
    /user/dshk/nsh_storage_volume.csh 파일에서 계정별 스토리지 정보를 추출합니다.
    형식: / 계정명 UID GID 스토리지 볼륨 ...
    """
    storage_map = {}
    file_path = "/user/dshk/nsh_storage_volume.csh"
    
    try:
        with open(file_path, 'r') as f:
            for line in f:
                parts = line.split()
                if len(parts) >= 5:
                    account = parts[1]
                    if account in target_accounts:
                        storage_map[account] = parts[4] # 스토리지 부분 추출
        return storage_map
    except FileNotFoundError:
        print(f"Error: {file_path} 파일을 찾을 수 없습니다.")
        sys.exit(1)

def run_quota_cmd(account, storage):
    """
    스토리지 유형(Dell vs NetApp)을 판별하여 적절한 명령어를 실행합니다.
    """
    # 1. NetApp 판별 및 호스트명 변환 (filer -> node, 접미사 mgt-00)
    if "filer" in storage.lower():
        # 예: storage01-filer -> storage01-node-mgt-00
        netapp_host = storage.lower().replace("filer", "node") + "-mgt-00"
        cmd = f"sudo ssh -l admin {netapp_host} quota report | grep {account}"
        vendor = "NetApp"
    
    # 2. Dell (Isilon) 판별
    else:
        cmd = f"sudo ssh {storage} isi quota list -v | grep {account}"
        vendor = "Dell"

    print(f"--- [{vendor}] Account: {account} (Storage: {storage}) ---")
    
    try:
        # 명령어 실행 및 결과 출력
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        if result.stdout:
            print(result.stdout.strip())
        else:
            print(f"No quota information found for {account}.")
    except Exception as e:
        print(f"Execution Error: {e}")
    print("\n")

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 inode.py <account1> <account2> ...")
        return

    target_accounts = sys.argv[1:]
    storage_info = get_storage_info(target_accounts)

    for account in target_accounts:
        if account in storage_info:
            run_quota_cmd(account, storage_info[account])
        else:
            print(f"Account '{account}' not found in storage mapping file.\n")

if __name__ == "__main__":
    main()
