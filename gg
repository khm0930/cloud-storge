#!/bin/bin/csh -f

# 1. 인자가 없으면 사용법 출력
if ($#argv == 0) then
    echo "Usage: inode <account1> <account2> ..."
    exit 1
endif

# 2. 입력받은 모든 계정에 대해 반복 실행
foreach acc ($argv)
    # nsh_storage_volume.csh를 실행한 결과에서 해당 계정 줄을 찾고 4번째 단어(스토리지) 추출
    set storage = `source /user/dshk/nsh_storage_volume.csh | grep "^$acc " | awk '{print $4}'`

    if ("$storage" == "") then
        echo "--- [Error] $acc : 스토리지 정보를 찾을 수 없습니다. ---"
        continue
    endif

    echo "--- Checking Quota for $acc on $storage ---"

    # 3. 스토리지 이름에 'filer'가 들어있는지에 따라 명령어 분기
    if ("$storage" =~ *filer*) then
        # NetApp: filer -> node 변경 및 -mgt-00 추가
        set netapp_host = `echo $storage | sed 's/filer/node/'`"-mgt-00"
        sudo ssh -l admin $netapp_host "quota report | grep $acc"
    else
        # Dell (Isilon)
        sudo ssh $storage "isi quota list -v | grep $acc"
    endif

    echo ""
end
